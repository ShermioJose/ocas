              "path": ["api", "auth", "logout"]
            }
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"type\": \"register\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/resend-otp",
              "host": ["{{base_url}}"],
